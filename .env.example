# Database
DATABASE_URL=postgresql+asyncpg://vegrecipes:vegrecipes@postgres:5432/vegrecipes
DATABASE_URL_SYNC=postgresql://vegrecipes:vegrecipes@postgres:5432/vegrecipes

# Redis
REDIS_URL=redis://redis:6379/0

# Elasticsearch
ELASTICSEARCH_URL=http://elasticsearch:9200

# MinIO / S3
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=vegrecipes
S3_SECRET_KEY=vegrecipes_secret
S3_BUCKET=vegrecipes-media

# JWT
SECRET_KEY=change-me-in-production-use-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key

# Stripe
STRIPE_SECRET_KEY=sk_test_your-stripe-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_PRO_MONTHLY_PRICE_ID=price_your-monthly-id
STRIPE_PRO_YEARLY_PRICE_ID=price_your-yearly-id

# OpenAI (Whisper for recipe import)
OPENAI_API_KEY=your-openai-api-key

# App
# APP_URL — used for Stripe redirect URLs and email links. Change to your real domain in production.
APP_URL=http://localhost:3000
APP_ENV=development
# ⚠️  NEVER set DEBUG=true in production — it exposes stack traces
DEBUG=false
# Add your production domain when deploying: ["https://vegrecipes.ru","http://localhost:3000"]
CORS_ORIGINS=["http://localhost:3000","http://localhost:19006"]

# Sentry (leave empty to disable error tracking)
SENTRY_DSN=

# SMTP (email verification & password reset)
# Leave SMTP_HOST empty to print tokens to stdout in development mode
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@vegrecipes.ru
