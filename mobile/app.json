{
  "expo": {
    "name": "VegRecipes",
    "slug": "vegrecipes",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "vegrecipes",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#f0fdf4"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.vegrecipes.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Нужен доступ к камере для сканирования продуктов в холодильнике и AR-режима готовки",
        "NSPhotoLibraryUsageDescription": "Нужен доступ к фотогалерее для загрузки фото блюд",
        "NSHealthShareUsageDescription": "Для синхронизации данных об активности и здоровье",
        "NSHealthUpdateUsageDescription": "Для записи питания в Apple Health"
      },
      "entitlements": {
        "com.apple.developer.healthkit": true,
        "com.apple.developer.healthkit.background-delivery": true
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#f0fdf4"
      },
      "package": "com.vegrecipes.app",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "ACTIVITY_RECOGNITION"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-camera",
        { "cameraPermission": "Нужна камера для сканирования продуктов" }
      ],
      [
        "expo-image-picker",
        { "photosPermission": "Нужен доступ к фотогалерее" }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
